#include <stdio.h>
int main() 
{
    int n,m,i,j,s=0;
    printf("enter number of rows\n");
    scanf("%d",&n);
    printf("enter number of columns\n");
    scanf("%d",&m);
    int a[n][m];
    printf("enter elements\n");
    for(int i=0;i<n;i++)
    {
         for(int j=0;j<m;j++)
         {
             scanf("%d",&a[i][j]);
         }
    }
    for(int i=0;i<n;i++)
    {
         for(int j=0;j<m;j++)
         {
            if(i==j)
            {
                s=s+a[i][j];
            }
             
          }
    }
    printf("sum of diagonal matrix is %d",s);
         
    return 0;
    }
    

