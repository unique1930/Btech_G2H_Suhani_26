#include <stdio.h>
int main() 
 {
    int a[20],s=0,n;
    float avg;
    printf("enter size of an array\n");
    scanf("%d",&n);
    printf("enter elements\n");
     for(int i=1;i<=n;i++)
    {
        scanf("%d",&a[i]);
    }
    
    for(int i=1;i<=n;i++)
    {
        s=s+a[i];
    }
       avg=s/n;
 printf("sum is %d\n",s);
 printf("average is %f",avg);
 return 0;
}
